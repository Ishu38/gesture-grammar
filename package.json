{
  "name": "mlaf",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others --restart-tries 3 --restart-after 2000 --names grammar,vite --prefix-colors blue,magenta \"python3 -m uvicorn services.grammar_engine.app.main:app --host 0.0.0.0 --port 8300\" \"vite\"",
    "dev:frontend": "vite",
    "dev:grammar": "python3 -m uvicorn services.grammar_engine.app.main:app --host 0.0.0.0 --port 8300",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile:grammar": "nearleyc src/grammar/grammar.ne -o src/grammar/compiledGrammar.cjs"
  },
  "dependencies": {
    "@mediapipe/drawing_utils": "^0.3.1675466124",
    "@mediapipe/tasks-vision": "^0.10.32",
    "graphology": "^0.26.0",
    "graphology-shortest-path": "^2.1.0",
    "graphology-traversal": "^0.3.1",
    "nearley": "^2.20.1",
    "onnxruntime-web": "^1.24.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "workbox-window": "^7.4.0"
  }
}
